{
  "name": "programmatic-seo-engine",
  "version": "1.0.0",
  "description": "Programmatic SEO engine with Astro + Payload CMS",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:cms": "cd apps/cms && npm run dev",
    "dev:web": "cd apps/web && npm run dev",
    "build": "npm run build:cms && npm run build:web",
    "build:cms": "cd apps/cms && npm run build",
    "build:web": "cd apps/web && npm run build",
    "generate": "node scripts/generate-content.js",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "eslint": "^8.0.0"
  }
}
