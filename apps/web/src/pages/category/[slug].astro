---
// Category listing page
import { getCategories, getArticles } from '../../lib/cms';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';

export async function getStaticPaths() {
  try {
    const data = await getCategories(100);
    return data.docs.map((cat: any) => ({
      params: { slug: cat.slug },
      props: { category: cat },
    }));
  } catch {
    return [];
  }
}

const { category } = Astro.props;
let articles: any[] = [];
try {
  const data = await getArticles(50, 1, category.slug);
  articles = data.docs || [];
} catch {
  articles = [];
}

const title = `${category.name} - Articles & Guides`;
const description = category.description || `Browse our latest articles about ${category.name}. Expert guides, reviews, and insights.`;
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead title={title} description={description} />
  <style>
    main { max-width: 960px; margin: 0 auto; padding: 2em 1em; }
    .category-header { text-align: center; padding: 40px 0; }
    .category-header h1 { margin: 0 0 12px 0; }
    .article-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 24px; }
    .article-card { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; transition: box-shadow 0.2s; }
    .article-card:hover { box-shadow: 0 10px 25px rgba(0,0,0,0.1); }
    .article-card img { width: 100%; height: 200px; object-fit: cover; }
    .article-card .content { padding: 20px; }
    .article-card h3 { margin: 0 0 8px 0; font-size: 18px; }
    .article-card p { color: #666; font-size: 14px; margin: 0; }
    .article-card .date { color: #999; font-size: 12px; margin-top: 12px; }
    a { text-decoration: none; color: inherit; }
  </style>
</head>
<body>
  <Header />
  <main>
    <div class="category-header">
      <h1>{category.name}</h1>
      <p>{description}</p>
    </div>

    <div class="article-grid">
      {articles.map((article) => (
        <a href={`/blog/${article.slug}`} class="article-card">
          <img src={article.featuredImage || '/blog-placeholder-1.jpg'} alt={article.title} />
          <div class="content">
            <h3>{article.title}</h3>
            <p>{article.excerpt?.substring(0, 100)}...</p>
            <div class="date"><FormattedDate date={new Date(article.publishedDate)} /></div>
          </div>
        </a>
      ))}
    </div>

    {articles.length === 0 && (
      <p style="text-align: center; color: #666; padding: 60px 0;">No articles in this category yet. Check back soon!</p>
    )}
  </main>
  <Footer />
</body>
</html>
