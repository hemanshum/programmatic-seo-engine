{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd apps/web && npm install && npm run build"
  },
  "deploy": {
    "startCommand": "cd apps/web && npx serve dist/ -l 4321",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
